<Window x:Class="ClickTool.RecordEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="步骤列表"
        Width="1020"
        Height="740"
        WindowStartupLocation="CenterOwner"
        Background="#0B121A"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp">

    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#FFF3F6FA" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FFA8BAC8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF1ED7B5" />
        <SolidColorBrush x:Key="WarmBrush" Color="#FFFFD369" />

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#17283B" />
            <Setter Property="BorderBrush" Value="#24405C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="4,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F334A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#284360" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="11.5" />
        </Style>

        <Style x:Key="EditBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#111C29" />
            <Setter Property="BorderBrush" Value="#22344C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Width" Value="84" />
        </Style>

        <Style x:Key="SummaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsesWarmSummaryColor}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource WarmBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16,12"
                Background="#111B28"
                BorderBrush="#203448"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="步骤列表"
                               Foreground="{StaticResource InkBrush}"
                               FontFamily="Bahnschrift"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock x:Name="TxtDescription"
                               Margin="0,6,0,0"
                               Text="右侧 3 个数字框依次是 X 坐标、Y 坐标、等待时间(ms)。支持按住 Shift 区间勾选，也可以按住鼠标拖动连续勾选。黄色记录表示非鼠标移动操作。"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="TxtStatus"
                               Margin="0,8,0,0"
                               Text="准备编辑步骤记录。"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock x:Name="TxtCounts"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Bahnschrift"
                           FontSize="14" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Padding="14"
                Background="#0F1824"
                BorderBrush="#203246"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <WrapPanel>
                        <Button x:Name="BtnMerge"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="合并为一步"
                                Click="BtnMerge_Click" />
                        <Button x:Name="BtnSplit"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="逐条分步"
                                Click="BtnSplit_Click" />
                        <Button x:Name="BtnCopySelectedSteps"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="复制选中步骤"
                                Click="BtnCopySelectedSteps_Click" />
                        <Button x:Name="BtnDeleteSelected"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="删除选中"
                                Click="BtnDeleteSelected_Click" />
                        <Button x:Name="BtnDeleteAll"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="清空当前"
                                Click="BtnDeleteAll_Click" />
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Content="关闭"
                                Click="BtnClose_Click" />
                    </WrapPanel>
                </Viewbox>

                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <WrapPanel Margin="0,2,0,0" VerticalAlignment="Center">
                        <TextBlock Margin="0,0,12,14"
                                   VerticalAlignment="Center"
                                   Text="批量等待时间(ms)"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12" />
                        <TextBox x:Name="TxtBatchDelayMs"
                                 Width="96"
                                 Margin="0,0,14,14"
                                 Style="{StaticResource EditBoxStyle}"
                                 Text="0" />
                        <Button x:Name="BtnApplyBatchDelay"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="应用到选中记录"
                                Click="BtnApplyBatchDelay_Click" />
                    </WrapPanel>
                </Viewbox>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Padding="12"
                Background="#0E1722"
                BorderBrush="#203246"
                BorderThickness="1"
                CornerRadius="22">
            <Grid x:Name="SelectionSurface"
                  PreviewMouseLeftButtonDown="SelectionSurface_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="SelectionSurface_PreviewMouseMove"
                  PreviewMouseLeftButtonUp="SelectionSurface_PreviewMouseLeftButtonUp"
                  LostMouseCapture="SelectionSurface_LostMouseCapture">
                <TextBlock x:Name="TxtEmptyState"
                           Text="当前没有可编辑的录制。"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="13"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Visibility="Collapsed" />

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LstActionGroups">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="{Binding IsExpanded}"
                                          Expanded="EditorGroup_Expanded"
                                          Collapsed="EditorGroup_Collapsed">
                                    <Expander.Header>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                Background="#111C29"
                                                BorderBrush="#1F3145"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        MinWidth="72"
                                                        Margin="0,0,12,0"
                                                        Padding="10,8"
                                                        Background="#102232"
                                                        BorderBrush="#23445B"
                                                        BorderThickness="1"
                                                        CornerRadius="14">
                                                    <TextBlock Text="{Binding StepLabel}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontFamily="Bahnschrift"
                                                               FontSize="13"
                                                               FontWeight="Bold" />
                                                </Border>

                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding Summary}"
                                                           Foreground="{StaticResource InkBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock Grid.Column="2"
                                                           Margin="12,0,12,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding CountLabel}"
                                                           Foreground="{StaticResource WarmBrush}"
                                                           FontFamily="Bahnschrift"
                                                           FontSize="12" />

                                                <Button Grid.Column="3"
                                                        Tag="{Binding StepNumber}"
                                                        Style="{StaticResource SmallButtonStyle}"
                                                        Content="复制此步"
                                                        Click="BtnCopyStep_Click" />
                                            </Grid>
                                        </Border>
                                    </Expander.Header>

                                    <ItemsControl ItemsSource="{Binding Actions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="12,0,0,8"
                                                        Padding="10"
                                                        Background="#101927"
                                                        BorderBrush="#1D3043"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Tag="{Binding Index}"
                                                        Loaded="ActionSelectionRow_Loaded"
                                                        Unloaded="ActionSelectionRow_Unloaded"
                                                        MouseEnter="ActionSelectionRow_MouseEnter">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
                                                                  Margin="0,0,10,0"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding IsSelected}"
                                                                  PreviewMouseLeftButtonDown="ActionSelectionCheckBox_PreviewMouseLeftButtonDown"
                                                                  MouseEnter="ActionSelectionCheckBox_MouseEnter"
                                                                  Click="ActionSelectionCheckBox_Click" />

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Style="{StaticResource SummaryTextStyle}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="{Binding BoundaryLabel}"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       FontSize="11" />
                                                        </StackPanel>

                                                        <TextBox Grid.Column="2"
                                                                 Margin="10,0,0,0"
                                                                 Style="{StaticResource EditBoxStyle}"
                                                                 Text="{Binding Action.X, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                        <TextBox Grid.Column="3"
                                                                 Margin="10,0,0,0"
                                                                 Style="{StaticResource EditBoxStyle}"
                                                                 Text="{Binding Action.Y, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                        <TextBox Grid.Column="4"
                                                                 Margin="10,0,0,0"
                                                                 Style="{StaticResource EditBoxStyle}"
                                                                 Text="{Binding Action.DelayMs, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                                        <StackPanel Grid.Column="5"
                                                                    Margin="10,0,0,0"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Button Tag="{Binding Index}"
                                                                    Style="{StaticResource SmallButtonStyle}"
                                                                    Content="{Binding BoundaryLabel}"
                                                                    Click="ActionStepBoundary_Click" />
                                                            <Button Tag="{Binding Index}"
                                                                    Style="{StaticResource SmallButtonStyle}"
                                                                    Content="保存"
                                                                    Click="BtnSaveActionEdit_Click" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="6"
                                                                    Margin="10,0,0,0"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Button Tag="{Binding Index}"
                                                                    Style="{StaticResource SmallButtonStyle}"
                                                                    Content="删除"
                                                                    Click="ActionDelete_Click" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Canvas x:Name="SelectionOverlay"
                        IsHitTestVisible="False"
                        Panel.ZIndex="10">
                    <Rectangle x:Name="SelectionRectangle"
                               Visibility="Collapsed"
                               Stroke="#FF1ED7B5"
                               StrokeThickness="1.5"
                               Fill="#331ED7B5" />
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</Window>
