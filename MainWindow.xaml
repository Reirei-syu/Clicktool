<Window x:Class="ClickTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickTool"
        Width="92"
        Height="92"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#FFF3F6FA" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FFA8BAC8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF1ED7B5" />
        <SolidColorBrush x:Key="WarmBrush" Color="#FFFFA65C" />
        <SolidColorBrush x:Key="PanelStrokeBrush" Color="#243A5B" />

        <LinearGradientBrush x:Key="WindowGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF112133" Offset="0" />
            <GradientStop Color="#FF0C1622" Offset="0.55" />
            <GradientStop Color="#FF091119" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="OrbGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF102335" Offset="0" />
            <GradientStop Color="#FF14364A" Offset="0.55" />
            <GradientStop Color="#FF1A4A54" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#17283B" />
            <Setter Property="BorderBrush" Value="#24405C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="4,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F334A" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2E5175" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#284360" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecordActionButtonActive" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="Background" Value="#3C302C" />
            <Setter Property="BorderBrush" Value="#98604A" />
        </Style>

        <Style x:Key="PlayActionButtonActive" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="Background" Value="#153730" />
            <Setter Property="BorderBrush" Value="#2AA88B" />
        </Style>

        <Style x:Key="WindowChromeButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#111E2D" />
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="MinWidth" Value="106" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Background" Value="#101A26" />
        </Style>

        <Style x:Key="HotkeyBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#111C29" />
            <Setter Property="BorderBrush" Value="#22344C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SurfaceTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#111C29" />
            <Setter Property="BorderBrush" Value="#22344C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#111C29" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#111C29" />
            <Setter Property="BorderBrush" Value="#22344C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#111C29" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#111C29" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFF3F6FA" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#214F57" />
            </Style.Resources>
        </Style>

        <Style x:Key="ResizeEdgeThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Root"
                                Background="#151D29"
                                BorderBrush="#294055"
                                BorderThickness="1"
                                CornerRadius="5"
                                Opacity="0.45" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResizeCornerThumbStyle" TargetType="Thumb" BasedOn="{StaticResource ResizeEdgeThumbStyle}">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="CompactView"
              Visibility="Visible"
              MouseLeftButtonDown="CompactView_MouseLeftButtonDown"
              MouseLeftButtonUp="CompactView_MouseLeftButtonUp"
              MouseMove="CompactView_MouseMove"
              MouseRightButtonUp="CompactView_MouseRightButtonUp">
            <Grid Width="78"
                  Height="78"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  ToolTip="左键直接播放，按住拖动移动，右键展开控制面板">
                <Ellipse Fill="#341ED7B5" />
                <Ellipse Width="72"
                         Height="72"
                         Fill="{StaticResource OrbGradientBrush}"
                         Stroke="#8A5DE5D0"
                         StrokeThickness="1.5">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="20"
                                          ShadowDepth="0"
                                          Color="#FF1ED7B5"
                                          Opacity="0.45" />
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="58"
                         Height="58"
                         Fill="#0E1622"
                         Stroke="#2C5B72"
                         StrokeThickness="1" />
                <Path Data="M 0 0 L 0 24 L 22 12 Z"
                      Width="22"
                      Height="24"
                      Stretch="Fill"
                      Fill="{StaticResource InkBrush}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="4,0,0,0" />
                <Border Width="18"
                        Height="18"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Background="#16314A"
                        BorderBrush="#32617A"
                        BorderThickness="1"
                        CornerRadius="9">
                    <TextBlock Text="R"
                               Foreground="{StaticResource WarmBrush}"
                               FontFamily="Bahnschrift"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Grid>

        <Border x:Name="ExpandedView"
                Visibility="Collapsed"
                CornerRadius="24"
                BorderBrush="{StaticResource PanelStrokeBrush}"
                BorderThickness="1"
                Background="{StaticResource WindowGradientBrush}"
                PreviewMouseLeftButtonDown="ExpandedView_PreviewMouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30"
                                  ShadowDepth="0"
                                  Color="#FF071018"
                                  Opacity="0.55" />
            </Border.Effect>

            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#111B28"
                        BorderBrush="#203448"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16,12"
                        MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Width="34" Height="34" Margin="0,0,12,0">
                            <Ellipse Fill="#102534" Stroke="#2A576A" StrokeThickness="1" />
                            <Path Data="M 0 0 L 0 16 L 14 8 Z"
                                  Width="14"
                                  Height="16"
                                  Stretch="Fill"
                                  Fill="{StaticResource AccentBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="2,0,0,0" />
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="ClickTool"
                                       Foreground="{StaticResource InkBrush}"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       FontWeight="Bold" />
                            <TextBlock Text="悬浮录制、方案切换和按步回放"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" />
                        </StackPanel>

                        <Button x:Name="BtnToggleBottomLayer"
                                Grid.Column="2"
                                Style="{StaticResource WindowChromeButton}"
                                Content="底"
                                ToolTip="置底或恢复置顶"
                                Click="BtnToggleBottomLayer_Click" />

                        <Button Grid.Column="3"
                                Style="{StaticResource WindowChromeButton}"
                                Margin="8,0,0,0"
                                Content="－"
                                ToolTip="收起到圆形播放按钮"
                                Click="BtnCollapse_Click" />

                        <Button Grid.Column="4"
                                Style="{StaticResource WindowChromeButton}"
                                Margin="8,0,0,0"
                                Content="×"
                                ToolTip="关闭"
                                Click="BtnClose_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="#101A26"
                        BorderBrush="#203246"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                            <UniformGrid Columns="5">
                                <Button x:Name="BtnRecord" Style="{StaticResource PrimaryActionButton}" Margin="0,0,10,0" Content="录制" Click="BtnRecord_Click" />
                                <Button x:Name="BtnPlayAll" Style="{StaticResource PrimaryActionButton}" Margin="0,0,10,0" Content="播放全部" Click="BtnPlayAll_Click" />
                                <Button x:Name="BtnLoopPlay" Style="{StaticResource PrimaryActionButton}" Margin="0,0,10,0" Content="循环播放" Click="BtnLoopPlay_Click" />
                                <Button x:Name="BtnStepPlay" Style="{StaticResource PrimaryActionButton}" Margin="0,0,10,0" Content="按步播放" Click="BtnStepPlay_Click" />
                                <Button x:Name="BtnStop" Style="{StaticResource PrimaryActionButton}" Margin="0" Content="停止" Click="BtnStop_Click" />
                            </UniformGrid>
                        </Viewbox>

                        <Viewbox Margin="0,12,0,0" Stretch="Uniform" StretchDirection="DownOnly">
                            <WrapPanel VerticalAlignment="Center">
                                <TextBlock Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           Text="循环次数"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12" />
                                <TextBox x:Name="TxtLoopCount"
                                         Width="88"
                                         Margin="0,0,12,0"
                                         VerticalContentAlignment="Center"
                                         Style="{StaticResource SurfaceTextBoxStyle}"
                                         Text="*" />
                                <TextBlock VerticalAlignment="Center"
                                           Text="输入 1-*，* 代表无限循环"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12" />
                            </WrapPanel>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Padding="14"
                        Background="#111A27"
                        BorderBrush="#203246"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="TxtStatus"
                                       Text="准备就绪。"
                                       Foreground="{StaticResource InkBrush}"
                                       FontFamily="Bahnschrift"
                                       FontSize="16"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="TxtHint"
                                       Margin="0,6,0,0"
                                       Text="先录制一段鼠标操作，再按需管理方案、打开步骤列表和设置热键。"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtActionCount" Text="操作 0 条" Foreground="{StaticResource WarmBrush}" FontFamily="Bahnschrift" FontSize="14" HorizontalAlignment="Right" />
                            <TextBlock x:Name="TxtStepCount" Margin="0,4,0,0" Text="步骤 0 组" Foreground="{StaticResource AccentBrush}" FontFamily="Bahnschrift" FontSize="14" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="#0F1824"
                        BorderBrush="#203246"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="方案列表"
                                       Foreground="{StaticResource InkBrush}"
                                       FontFamily="Bahnschrift"
                                       FontSize="15"
                                       FontWeight="Bold" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="切换方案、修改名称、另存方案和删除方案都在独立的方案列表窗口中完成。"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Viewbox Grid.Column="1" Stretch="Uniform" StretchDirection="DownOnly">
                            <Button x:Name="BtnOpenSchemeManager"
                                    Style="{StaticResource ToolbarButton}"
                                    Margin="10,0,0,0"
                                    Content="打开方案列表"
                                    Click="BtnOpenSchemeManager_Click" />
                        </Viewbox>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="#0F1824"
                        BorderBrush="#203246"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="步骤列表"
                                       Foreground="{StaticResource InkBrush}"
                                       FontFamily="Bahnschrift"
                                       FontSize="15"
                                       FontWeight="Bold" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="主面板不再显示步骤列表。步骤查看、折叠、合并、拆分和删除都在独立窗口中进行。"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Viewbox Grid.Column="1" Stretch="Uniform" StretchDirection="DownOnly">
                            <Button x:Name="BtnOpenRecordEditor"
                                    Style="{StaticResource ToolbarButton}"
                                    Margin="10,0,0,0"
                                    Content="打开步骤列表"
                                    Click="BtnOpenRecordEditor_Click" />
                        </Viewbox>
                    </Grid>
                </Border>

                <Border Grid.Row="5"
                        Margin="0,14,0,0"
                        Padding="14"
                        Background="#0E1722"
                        BorderBrush="#203246"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="当前方案摘要"
                                   Foreground="{StaticResource InkBrush}"
                                   FontFamily="Bahnschrift"
                                   FontSize="15"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="TxtSchemeSummary"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="6"
                        Margin="0,14,0,0"
                        Padding="14"
                        Background="#101925"
                        BorderBrush="#203246"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="窗口查看热键" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            <TextBox x:Name="TxtHotkeyEditorWindow"
                                     Style="{StaticResource HotkeyBoxStyle}"
                                     ToolTip="点击后直接按键，按 Esc 代表不设置"
                                     KeyDown="HotkeyBox_KeyDown"
                                     GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="录制热键" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            <TextBox x:Name="TxtHotkeyRecord"
                                     Style="{StaticResource HotkeyBoxStyle}"
                                     ToolTip="点击后直接按键，按 Esc 代表不设置"
                                     KeyDown="HotkeyBox_KeyDown"
                                     GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="播放热键" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            <TextBox x:Name="TxtHotkeyPlay"
                                     Style="{StaticResource HotkeyBoxStyle}"
                                     ToolTip="点击后直接按键，按 Esc 代表不设置"
                                     KeyDown="HotkeyBox_KeyDown"
                                     GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,10,0">
                            <TextBlock Text="按步播放热键" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            <TextBox x:Name="TxtHotkeyStep"
                                     Style="{StaticResource HotkeyBoxStyle}"
                                     ToolTip="点击后直接按键，按 Esc 代表不设置"
                                     KeyDown="HotkeyBox_KeyDown"
                                     GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,10,0">
                            <TextBlock Text="停止热键" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            <TextBox x:Name="TxtHotkeyStop"
                                     Style="{StaticResource HotkeyBoxStyle}"
                                     ToolTip="点击后直接按键，按 Esc 代表不设置"
                                     KeyDown="HotkeyBox_KeyDown"
                                     GotKeyboardFocus="HotkeyBox_GotKeyboardFocus" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="悬浮窗透明度" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                <Slider x:Name="SldOpacity"
                                        Grid.Column="1"
                                        Margin="12,0"
                                        Minimum="0.05"
                                        Maximum="1"
                                        TickFrequency="0.01"
                                        SmallChange="0.01"
                                        LargeChange="0.05"
                                        IsSnapToTickEnabled="False"
                                        ValueChanged="SldOpacity_ValueChanged" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="右键圆形按钮可再次进入这里"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Thumb Width="8"
               HorizontalAlignment="Left"
               Margin="6,26,0,26"
               Cursor="SizeWE"
               Style="{StaticResource ResizeEdgeThumbStyle}"
               DragDelta="ResizeLeft_DragDelta"
               Visibility="{Binding ElementName=ExpandedView, Path=Visibility}" />
        <Thumb Width="8"
               HorizontalAlignment="Right"
               Margin="0,26,6,26"
               Cursor="SizeWE"
               Style="{StaticResource ResizeEdgeThumbStyle}"
               DragDelta="ResizeRight_DragDelta"
               Visibility="{Binding ElementName=ExpandedView, Path=Visibility}" />
        <Thumb Height="8"
               VerticalAlignment="Top"
               Margin="26,6,26,0"
               Cursor="SizeNS"
               Style="{StaticResource ResizeEdgeThumbStyle}"
               DragDelta="ResizeTop_DragDelta"
               Visibility="{Binding ElementName=ExpandedView, Path=Visibility}" />
        <Thumb Height="8"
               VerticalAlignment="Bottom"
               Margin="26,0,26,6"
               Cursor="SizeNS"
               Style="{StaticResource ResizeEdgeThumbStyle}"
               DragDelta="ResizeBottom_DragDelta"
               Visibility="{Binding ElementName=ExpandedView, Path=Visibility}" />
        <Thumb HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="6"
               Cursor="SizeNWSE"
               Style="{StaticResource ResizeCornerThumbStyle}"
               DragDelta="ResizeTopLeft_DragDelta"
               Visibility="{Binding ElementName=ExpandedView, Path=Visibility}" />
        <Thumb HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,6,6,0"
               Cursor="SizeNESW"
               Style="{StaticResource ResizeCornerThumbStyle}"
               DragDelta="ResizeTopRight_DragDelta"
               Visibility="{Binding ElementName=ExpandedView, Path=Visibility}" />
        <Thumb HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Margin="6,0,0,6"
               Cursor="SizeNESW"
               Style="{StaticResource ResizeCornerThumbStyle}"
               DragDelta="ResizeBottomLeft_DragDelta"
               Visibility="{Binding ElementName=ExpandedView, Path=Visibility}" />
        <Thumb HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,6,6"
               Cursor="SizeNWSE"
               Style="{StaticResource ResizeCornerThumbStyle}"
               DragDelta="ResizeBottomRight_DragDelta"
               Visibility="{Binding ElementName=ExpandedView, Path=Visibility}" />
    </Grid>
</Window>
